@model Employee_Management_Mini_System.Models.Employee

@{
    ViewData["Title"] = "Delete Employee";
}

<div class="row justify-content-center mt-2">
    <div class="col-lg-8 col-md-10">
        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-arrow-left"></i> Back
            </a>
            <h2 class="m-0 text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>Delete Employee</h2>
        </div>

        <div class="alert alert-danger shadow-sm border-danger border-opacity-25" role="alert">
            <h4 class="alert-heading fw-bold"><i class="bi bi-exclamation-circle me-1"></i> Are you absolutely sure?</h4>
            <p class="mb-0">You are about to delete the employee record for <strong>@Model.FullName</strong>. This action cannot be undone.</p>
        </div>

        <div class="card shadow-sm border-0 mt-4">
            <div class="card-header bg-light py-3">
                <h5 class="mb-0 text-muted"><i class="bi bi-person-badge me-2"></i>Employee Details</h5>
            </div>
            <div class="card-body p-4">
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted fw-medium">@Html.DisplayNameFor(model => model.FullName)</div>
                    <div class="col-sm-8 fw-semibold fs-5">@Html.DisplayFor(model => model.FullName)</div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-4 text-muted fw-medium">@Html.DisplayNameFor(model => model.JobTitle)</div>
                    <div class="col-sm-8">@Html.DisplayFor(model => model.JobTitle)</div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-4 text-muted fw-medium">@Html.DisplayNameFor(model => model.Department)</div>
                    <div class="col-sm-8">
                        <span class="badge bg-info text-dark">@(Model.Department != null ? Model.Department.Name : "N/A")</span>
                    </div>
                </div>

                <hr class="my-4 text-muted opacity-25">

                <div class="row mb-3">
                    <div class="col-sm-4 text-muted fw-medium">@Html.DisplayNameFor(model => model.Email)</div>
                    <div class="col-sm-8"><i class="bi bi-envelope text-muted me-2"></i><a href="mailto:@Model.Email" class="text-decoration-none">@Html.DisplayFor(model => model.Email)</a></div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-4 text-muted fw-medium">@Html.DisplayNameFor(model => model.PhoneNumber)</div>
                    <div class="col-sm-8"><i class="bi bi-telephone text-muted me-2"></i>@Html.DisplayFor(model => model.PhoneNumber)</div>
                </div>

                <hr class="my-4 text-muted opacity-25">

                <div class="row mb-3">
                    <div class="col-sm-4 text-muted fw-medium">@Html.DisplayNameFor(model => model.HireDate)</div>
                    <div class="col-sm-8">@Model.HireDate.ToString("MMMM dd, yyyy")</div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-4 text-muted fw-medium">@Html.DisplayNameFor(model => model.IsActive)</div>
                    <div class="col-sm-8">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </div>
                </div>

                <div class="mt-5 border-top pt-4">
                    <form asp-action="Delete" method="post" class="d-flex justify-content-end gap-2">
                        <input type="hidden" asp-for="Id" />
                        <a asp-action="Index" class="btn btn-light border px-4 py-2 text-dark">Cancel</a>
                        <button type="submit" class="btn btn-danger px-4 py-2">
                            <i class="bi bi-trash gap-1"></i> Confirm Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
