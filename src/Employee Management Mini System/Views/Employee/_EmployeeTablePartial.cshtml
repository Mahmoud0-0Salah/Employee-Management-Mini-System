@model IEnumerable<Employee_Management_Mini_System.Models.Employee>

@{
    int currentPage = 1;
    if (int.TryParse(Context.Request.Query["pageNumber"], out int p)) 
    { 
        currentPage = p; 
    }
    else if (ViewData["CurrentPage"] != null)
    {
        currentPage = Convert.ToInt32(ViewData["CurrentPage"]);
    }
    
    int totalPages = 1;
    int totalRecords = 0;
    if (ViewData["TotalPages"] != null)
    {
        totalRecords = Convert.ToInt32(ViewData["TotalPages"]);
        int pageSize = 10;
        totalPages = (int)Math.Ceiling((double)totalRecords / pageSize);
        if (totalPages == 0) totalPages = 1;
    }
}

<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>@Html.DisplayNameFor(model => model.FullName)</th>
                <th>@Html.DisplayNameFor(model => model.JobTitle)</th>
                <th>@Html.DisplayNameFor(model => model.Department)</th>
                <th>Contact Info</th>
                <th>@Html.DisplayNameFor(model => model.HireDate)</th>
                <th>Status</th>
                <th class="text-end pe-4">Actions</th>
            </tr>
        </thead>
        <tbody class="border-top-0">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-medium text-dark ps-3">@Html.DisplayFor(modelItem => item.FullName)</td>
                        <td>@Html.DisplayFor(modelItem => item.JobTitle)</td>
                        <td>
                            <span class="badge bg-info text-dark">@(item.Department != null ? item.Department.Name : "N/A")</span>
                        </td>
                        <td>
                            <div class="text-muted"><small><i class="bi bi-envelope me-1"></i>@item.Email</small></div>
                            <div class="text-muted"><small><i class="bi bi-telephone me-1"></i>@item.PhoneNumber</small></div>
                        </td>
                        <td>@item.HireDate.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1">Active</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-2 py-1">Inactive</span>
                            }
                        </td>
                        <td class="text-end pe-3">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary shadow-sm" title="Edit">
                                <i class="bi bi-pencil"></i> <span class="d-none d-md-inline ms-1">Edit</span>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger shadow-sm ms-1" title="Delete">
                                <i class="bi bi-trash"></i> <span class="d-none d-md-inline ms-1">Delete</span>
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr class="no-results-row">
                    <td colspan="7" class="text-center py-5 text-muted">
                        <i class="bi bi-person-x fs-1 d-block mb-3 text-secondary"></i>
                        <h5 class="fw-normal">No employees found</h5>
                        <p class="mb-0">Try adjusting your search or add a new employee.</p>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="card-footer bg-white border-top-0 py-3">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
        <span class="text-muted small mb-2 mb-md-0">Page @currentPage of @totalPages (Total: @totalRecords entries)</span>
        <nav aria-label="Table navigation">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" href="#" data-page="@(currentPage - 1)">Previous</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(currentPage == i ? "active" : "")">
                        <a class="page-link" href="#" data-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                    <a class="page-link" href="#" data-page="@(currentPage + 1)">Next</a>
                </li>
            </ul>
        </nav>
    </div>
</div>
