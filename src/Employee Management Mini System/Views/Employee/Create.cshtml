@model Employee_Management_Mini_System.Models.Employee

@{
    ViewData["Title"] = "Add Employee";
}

<div class="row justify-content-center mt-2">
    <div class="col-lg-8 col-md-10">
        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-arrow-left"></i> Back
            </a>
            <h2 class="m-0"><i class="bi bi-person-plus text-primary me-2"></i>Add New Employee</h2>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-md-5">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <h5 class="text-muted mb-4 border-bottom pb-2">Personal Information</h5>
                    
                    <div class="row g-3 mb-4">
                        <div class="col-md-12 form-group">
                            <label asp-for="FullName" class="form-label fw-medium">Full Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="John Doe" />
                            <span asp-validation-for="FullName" class="text-danger small mt-1"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6 form-group">
                            <label asp-for="Email" class="form-label fw-medium">Email Address <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Email" class="form-control" placeholder="john.doe@example.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-6 form-group">
                            <label asp-for="PhoneNumber" class="form-label fw-medium">Phone Number <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="+1234567890" />
                            </div>
                            <span asp-validation-for="PhoneNumber" class="text-danger small mt-1"></span>
                        </div>
                    </div>

                    <h5 class="text-muted mb-4 mt-5 border-bottom pb-2">Employment Information</h5>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6 form-group">
                            <label asp-for="JobTitle" class="form-label fw-medium">Job Title <span class="text-danger">*</span></label>
                            <input asp-for="JobTitle" class="form-control" placeholder="e.g. Software Engineer" />
                            <span asp-validation-for="JobTitle" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-6 form-group">
                            <label asp-for="DepartmentId" class="form-label fw-medium">Department <span class="text-danger">*</span></label>
                            <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.DepartmentId">
                                <option value="">-- Select Department --</option>
                            </select>
                            <span asp-validation-for="DepartmentId" class="text-danger small mt-1"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6 form-group">
                            <label asp-for="HireDate" class="form-label fw-medium">Hire Date <span class="text-danger">*</span></label>
                            <input asp-for="HireDate" class="form-control" type="date" />
                            <span asp-validation-for="HireDate" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-6 form-group d-flex align-items-end pb-2">
                            <div class="form-check form-switch fs-5">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" role="switch" checked>
                                <label class="form-check-label fs-6 ms-2 pt-1" asp-for="IsActive">Account is Active</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5 border-top pt-4">
                        <a asp-action="Index" class="btn btn-light border px-4 py-2 me-md-2">Cancel</a>
                        <button type="submit" class="btn btn-primary px-5 py-2">
                            <i class="bi bi-save me-1"></i> Save Employee
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
