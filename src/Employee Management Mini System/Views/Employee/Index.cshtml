@using Employee_Management_Mini_System.Services.Contracts
@inject IDepartmentService DepartmentService
@model IEnumerable<Employee_Management_Mini_System.Models.Employee>

@{
    ViewData["Title"] = "Employees";
    
    int currentPage = 1;
    if (int.TryParse(Context.Request.Query["pageNumber"], out int p)) 
    { 
        currentPage = p; 
    }
    
    int totalPages = 1;
    int totalRecords = 0;
    if (ViewData["TotalPages"] != null)
    {
        totalRecords = Convert.ToInt32(ViewData["TotalPages"]);
        int pageSize = 10;
        totalPages = (int)Math.Ceiling((double)totalRecords / pageSize);
        if (totalPages == 0) totalPages = 1;
    }

    var departments = await DepartmentService.GetDepartments();
    var deptList = new SelectList(departments, "Id", "Name", Context.Request.Query["departmentID"]);
    string actionName = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="m-0"><i class="bi bi-people text-primary me-2"></i>Employee Directory</h2>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Add Employee
    </a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form id="searchForm" asp-action="Search" method="get" class="row gx-2 gy-2 align-items-center">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="searchString" class="form-control border-start-0" placeholder="Search by name..." value="@ViewData["CurrentFilter"]" />
                </div>
            </div>
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-building text-muted"></i></span>
                    <select name="departmentID" class="form-select border-start-0" asp-items="deptList">
                        <option value="-1">All Departments</option>
                    </select>
                </div>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-secondary">Search</button>
                <button type="button" id="clearSearchBtn" class="btn btn-link text-decoration-none text-muted">Clear</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm" id="employee-list-container">
    @await Html.PartialAsync("_EmployeeTablePartial", Model)
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function() {
            function fetchEmployees(pageNumber) {
                var form = $('#searchForm');
                var url = form.attr('action') || '@Url.Action("Search", "Employee")';
                var searchString = $('input[name="searchString"]').val();
                var departmentID = $('select[name="departmentID"]').val();
                
                $('#employee-list-container').css('opacity', '0.6');
                
                $.ajax({
                    url: url,
                    type: 'GET',
                    data: {
                        searchString: searchString,
                        departmentID: departmentID,
                        pageNumber: pageNumber
                    },
                    success: function(response) {
                        $('#employee-list-container').html(response);
                        $('#employee-list-container').css('opacity', '1');
                    },
                    error: function(xhr, status, error) {
                        console.error("Error loading search results:", error);
                        $('#employee-list-container').css('opacity', '1');
                    }
                });
            }

            $('#searchForm').on('submit', function(e) {
                e.preventDefault();
                fetchEmployees(1);
            });

            $('select[name="departmentID"]').on('change', function() {
                fetchEmployees(1);
            });

            var typingTimer;
            var doneTypingInterval = 350;
            $('input[name="searchString"]').on('keyup input', function() {
                clearTimeout(typingTimer);
                typingTimer = setTimeout(function() {
                    fetchEmployees(1);
                }, doneTypingInterval);
            });

            $(document).on('click', '#employee-list-container .pagination .page-link', function(e) {
                e.preventDefault();
                var page = $(this).attr('data-page');
                if (page && !$(this).parent().hasClass('disabled') && !$(this).parent().hasClass('active')) {
                    fetchEmployees(page);
                }
            });

            $('#clearSearchBtn').on('click', function(e) {
                e.preventDefault();
                $('input[name="searchString"]').val('');
                $('select[name="departmentID"]').val('-1');
                fetchEmployees(1);
            });
        });
    </script>
}
